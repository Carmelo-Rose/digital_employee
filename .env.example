# 复制为 .env 后填入真实值；不填则相关能力自动走 mock，不影响 Demo 跑通。

# ===== LLM 洞察 =====
# 取值：mock（默认）| mimo | claude | anthropic（后三者走 Anthropic 兼容端点）| openai | qwen
LLM_PROVIDER=mimo
# Anthropic 兼容端点（MiMo-V2.5 / Claude 共用）
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_API_KEY=tp-你的key
LLM_MODEL=mimo-v2.5
# 其他 provider（暂未实现，预留）
OPENAI_API_KEY=
DASHSCOPE_API_KEY=        # 通义千问 Qwen

# ===== 推送渠道 =====
# 企业微信群机器人 webhook（机器人设置里复制）
WECOM_WEBHOOK_URL=
# 飞书自定义机器人 webhook
FEISHU_WEBHOOK_URL=

# ===== 分析阈值（可选，留空用默认）=====
# 已付款未发货：超过多少小时算严重
PAY_NO_SHIP_HOURS=48
# 物流多少天无更新算超时
LOGISTICS_STALE_DAYS=3
# 退款中多少天未完成算异常
REFUND_PENDING_DAYS=2
# 库存低于多少算预警
STOCK_LOW_THRESHOLD=5

# ===== 自主触发（定时跑，让数字员工"自己上班"，无需人工上传）=====
# 总开关：true 时随服务启动定时任务；默认 false（手动上传模式）
SCHEDULER_ENABLED=false
# 触发节奏：cron 优先（标准 5 段，如 "0 9 * * *" 每天 09:00）
SCHEDULER_CRON=0 9 * * *
# cron 留空且此值>0 时，按分钟间隔跑（演示用，如 1 表示每分钟）
SCHEDULER_INTERVAL_MINUTES=0
SCHEDULER_TIMEZONE=Asia/Shanghai
# 数据源（当前为固定文件路径，留空用 data/sample_orders.xlsx）
SCHEDULER_INPUT_FILE=
# 定时任务是否调用真实 LLM 写日报（默认 false 走 mock）
SCHEDULER_USE_LLM=false
SCHEDULER_SEND_WECOM=true
# true：自动跑完只推"待确认"通知，等人确认再发正式日报（保留 HITL）
# false（默认）：自动批准直接推送，真正无人值守闭环
SCHEDULER_REQUIRE_REVIEW=false
